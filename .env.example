# ─── Telegram bot ───────────────────────────────────────────
# From @BotFather (/newbot). REQUIRED for real auth + bot webhook.
TELEGRAM_BOT_TOKEN=
# NOTE: the webhook secret is DERIVED from the bot token automatically
# (see deriveWebhookSecret in src/lib/telegram-auth.ts). No separate var needed.

# ─── App URL ────────────────────────────────────────────────
# Public HTTPS URL of the deployed app (Railway domain), no trailing slash.
# Used by the bot to open the Mini App and to register the webhook.
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# ─── Supabase (optional) ────────────────────────────────────
# Leave BLANK to run in demo mode (in-memory data, no backend).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
